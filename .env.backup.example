# ────────────────────────────────────────────────────────────────────────
# Identifiants pour le script de sauvegarde (scripts/backup.mjs)
# Copie ce fichier en `.env.backup` et remplis les valeurs.
# ⚠️ .env.backup est ignoré par git — ne JAMAIS le committer.
# ────────────────────────────────────────────────────────────────────────

# Connexion Postgres directe — pour le dump complet de la base.
# Supabase → Settings → Database → Connection string → "URI"
# (remplace [YOUR-PASSWORD] par le mot de passe de la base)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres

# Pour télécharger les fichiers Storage (accès admin).
# Supabase → Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # clé "service_role" (secrète)
